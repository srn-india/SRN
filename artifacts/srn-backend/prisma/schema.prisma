generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MEMBER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id            String         @id @default(uuid())
  firstName     String
  lastName      String
  email         String         @unique
  phone         String?
  state         String?
  district      String?
  gender        String?
  dateOfBirth   DateTime?
  password      String?
  avatar        String?
  twoFactorSecret String?
  isTwoFactorEnabled Boolean @default(false)
  role          Role           @default(USER)
  provider      AuthProvider   @default(LOCAL)
  isVerified    Boolean        @default(false)
  otpCode       String?
  otpExpires    DateTime?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships   Membership[]
  payments      Payment[]
  posts         Post[]
  forumThreads  ForumThread[]
  forumComments ForumComment[]
  notifications Notification[]
  eventRegistrations EventRegistration[]
  complaints    Complaint[]
  janmantArticles JanmantArticle[]
  postApplications PostApplication[]
}

model Membership {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      String
  startDate DateTime
  endDate   DateTime
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  transactionId String?       @unique
  provider      String        @default("RAZORPAY")
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
}

model Post {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  isPremium Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String
  date        DateTime
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  registrations EventRegistration[]

  @@index([date])
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

model ForumThread {
  id        String   @id @default(uuid())
  title     String
  content   String
  imageUrl  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  comments  ForumComment[]

  @@index([userId])
}

model ForumComment {
  id        String      @id @default(uuid())
  content   String
  threadId  String
  userId    String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([threadId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Complaint {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket      String   @unique
  fullName    String
  email       String
  phone       String
  state       String
  category    String
  subject     String
  description String
  fileUrl     String?
  status       String   @default("Pending")
  isPublished  Boolean  @default(false)
  titleEn      String?
  titleHi      String?
  resolutionEn String?
  resolutionHi String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model JanmantArticle {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorName      String
  email           String
  phone           String
  articleCategory String
  title           String
  summary         String
  content         String
  coverImageUrl   String?
  status          String   @default("Pending") // Pending, Approved, Rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model PostApplication {
  id                 String   @id @default(uuid())
  userId             String?
  user               User?    @relation(fields: [userId], references: [id])
  fullName           String
  dob                String
  gender             String
  email              String
  phone              String
  address            String
  qualification      String
  appliedPosition    String
  currentOccupation  String?
  socialContribution String
  whyJoin            String
  resumeUrl          String?
  status             String   @default("Pending") // Pending, Approved, Rejected
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}
